# ============================================================
# EVOLUTY BACKEND — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# NE JAMAIS committer .env dans git
# ============================================================

# Serveur
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5500

# Chiffrement AES-256 (générer avec : node -e "require('crypto').randomBytes(32).toString('hex')" )
ENCRYPTION_KEY=REMPLACER_PAR_64_CARACTERES_HEX_GENERES_ALEATOIREMENT

# ── API Pappers (identité entreprise) ──────────────────────
# https://www.pappers.fr/api
PAPPERS_API_KEY=

# Fallback : API publique INSEE/SIRENE (sans clé pour usage modéré)
# https://api.insee.fr/catalogue/site/themes/wso2/subthemes/insee/pages/item-info.jag?name=Sirene&version=V3
INSEE_API_KEY=

# ── Open Banking — Bridge ──────────────────────────────────
# https://bridgeapi.io/
BRIDGE_CLIENT_ID=
BRIDGE_CLIENT_SECRET=
BRIDGE_REDIRECT_URI=http://localhost:3001/api/banking/callback

# ── CRM ───────────────────────────────────────────────────
# HubSpot : https://developers.hubspot.com/
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_REDIRECT_URI=http://localhost:3001/api/crm/hubspot/callback

# Pipedrive : https://developers.pipedrive.com/
PIPEDRIVE_CLIENT_ID=
PIPEDRIVE_CLIENT_SECRET=
PIPEDRIVE_REDIRECT_URI=http://localhost:3001/api/crm/pipedrive/callback

# ── Facturation ───────────────────────────────────────────
# Stripe : https://stripe.com/docs/api
STRIPE_SECRET_KEY=

# ── SIRH ──────────────────────────────────────────────────
# PayFit : https://developers.payfit.io/
PAYFIT_CLIENT_ID=
PAYFIT_CLIENT_SECRET=
PAYFIT_REDIRECT_URI=http://localhost:3001/api/sirh/payfit/callback

# Lucca : https://developer.lucca.fr/
LUCCA_CLIENT_ID=
LUCCA_CLIENT_SECRET=
LUCCA_REDIRECT_URI=http://localhost:3001/api/sirh/lucca/callback

# ── Infogreffe ────────────────────────────────────────────
# https://opendata.infogreffe.fr/
INFOGREFFE_API_KEY=

# ── Base de données (optionnel selon déploiement) ─────────
# DATABASE_URL=postgresql://user:password@host:5432/evoluty
