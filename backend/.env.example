# ── Application ────────────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=https://ton-github-pages.github.io
BACKEND_URL=https://ton-backend.railway.app

# ── Kinde (https://app.kinde.com) ──────────────────────────
# 1. Cree une "Business" sur app.kinde.com
# 2. Dans ton app Kinde > Details, copie ces valeurs :
KINDE_DOMAIN=https://TON_APP.kinde.com
KINDE_CLIENT_ID=xxx
KINDE_CLIENT_SECRET=xxx
KINDE_REDIRECT_URI=https://ton-backend.railway.app/callback

# ── Stripe (https://dashboard.stripe.com) ──────────────────
# 4 Prix a creer dans Stripe > Produits :
#   Croissance mensuel : 275€/mois (recurring monthly)
#   Croissance annuel  : 2808€/an  (234€/mois * 12)
#   Cession mensuel    : 355€/mois (recurring monthly)
#   Cession annuel     : 3624€/an  (302€/mois * 12)
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_CROISSANCE_MONTHLY=price_xxx
STRIPE_PRICE_CROISSANCE_ANNUAL=price_xxx
STRIPE_PRICE_CESSION_MONTHLY=price_xxx
STRIPE_PRICE_CESSION_ANNUAL=price_xxx

# ── Session ─────────────────────────────────────────────────
SESSION_SECRET=change-this-to-a-long-random-secret

# ── Mistral IA ──────────────────────────────────────────────
MISTRAL_API_KEY=xxx
